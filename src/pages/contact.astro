---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Contact" description="Get in touch with the Oak Ridge High School Orchestra.">
  <!-- Page Header -->
  <section class="bg-navy-900 text-white py-16">
    <div class="max-w-6xl mx-auto px-4 text-center">
      <h1 class="font-serif text-4xl font-bold mb-3">Contact Us</h1>
      <p class="text-navy-200 text-lg">We'd love to hear from you</p>
    </div>
  </section>

  <section class="py-16">
    <div class="max-w-4xl mx-auto px-4">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
        <!-- Form -->
        <div>
          <h2 class="font-serif text-2xl font-bold mb-6">Send a Message</h2>
          <form name="contact" method="POST" data-netlify="true" class="space-y-5">
            <input type="hidden" name="form-name" value="contact" />
            <div class="grid grid-cols-2 gap-4">
              <div>
                <label for="first-name" class="block text-sm font-medium text-navy-700 mb-1">First Name</label>
                <input
                  type="text"
                  id="first-name"
                  name="first-name"
                  required
                  class="w-full px-4 py-2 border border-navy-200 rounded-md focus:outline-none focus:ring-2 focus:ring-gold-400 focus:border-transparent"
                />
              </div>
              <div>
                <label for="last-name" class="block text-sm font-medium text-navy-700 mb-1">Last Name</label>
                <input
                  type="text"
                  id="last-name"
                  name="last-name"
                  required
                  class="w-full px-4 py-2 border border-navy-200 rounded-md focus:outline-none focus:ring-2 focus:ring-gold-400 focus:border-transparent"
                />
              </div>
            </div>
            <div>
              <label for="email" class="block text-sm font-medium text-navy-700 mb-1">Email</label>
              <input
                type="email"
                id="email"
                name="email"
                required
                class="w-full px-4 py-2 border border-navy-200 rounded-md focus:outline-none focus:ring-2 focus:ring-gold-400 focus:border-transparent"
              />
            </div>
            <div>
              <label for="message" class="block text-sm font-medium text-navy-700 mb-1">Message</label>
              <textarea
                id="message"
                name="message"
                rows="5"
                required
                class="w-full px-4 py-2 border border-navy-200 rounded-md focus:outline-none focus:ring-2 focus:ring-gold-400 focus:border-transparent resize-y"
              ></textarea>
            </div>
            <button
              type="submit"
              class="bg-navy-900 text-white px-8 py-3 rounded-md font-medium hover:bg-navy-800 transition-colors w-full sm:w-auto"
            >
              Send Message
            </button>
          </form>
        </div>

        <!-- Info -->
        <div>
          <h2 class="font-serif text-2xl font-bold mb-6">Get in Touch</h2>
          <div class="space-y-6 text-navy-700">
            <div>
              <h3 class="font-semibold text-navy-900 mb-1">Address</h3>
              <p>Oak Ridge High School</p>
              <p>1450 Oak Ridge Turnpike</p>
              <p>Oak Ridge, TN 37830</p>
            </div>
            <div>
              <h3 class="font-semibold text-navy-900 mb-1">Email</h3>
              <a href="mailto:orhsorcb@gmail.com" class="text-gold-600 hover:underline">
                orhsorcb@gmail.com
              </a>
            </div>
            <div>
              <h3 class="font-semibold text-navy-900 mb-1">Follow Us</h3>
              <div class="flex gap-4 mt-2">
                <a
                  href="https://www.facebook.com/ORHSstrings"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-navy-600 hover:text-gold-600 transition-colors"
                >
                  Facebook
                </a>
                <a
                  href="https://twitter.com/ORHSOrchestra"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-navy-600 hover:text-gold-600 transition-colors"
                >
                  X (Twitter)
                </a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
