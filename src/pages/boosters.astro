---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Boosters" description="Support the ORHS Orchestra Boosters - a 501(c)(3) organization.">
  <!-- Page Header -->
  <section class="bg-navy-900 text-white py-16">
    <div class="max-w-6xl mx-auto px-4 text-center">
      <h1 class="font-serif text-4xl font-bold mb-3">ORHS Orchestra Boosters</h1>
      <p class="text-navy-200 text-lg">Supporting excellence in music education</p>
    </div>
  </section>

  <!-- Mission -->
  <section class="py-16">
    <div class="max-w-4xl mx-auto px-4">
      <div class="bg-navy-50 rounded-xl p-6 md:p-8 mb-12">
        <h2 class="font-serif text-2xl font-bold mb-4">Our Mission</h2>
        <p class="text-navy-700 leading-relaxed mb-4">
          The orchestra boosters is committed to the importance and benefits of studying music as
          part of a student's education. It is our mission to support the Oak Ridge High School
          (ORHS) Orchestra Program, in providing quality musical experiences for students. We seek
          to provide additional resources and opportunities for students above and beyond those
          provided by Oak Ridge Schools. We are advocates for the life-long rewards of music and
          encourage our students to aspire to their highest level of musical achievement.
        </p>
        <p class="text-sm text-navy-500">
          The Orchestra Parents dba ORHS Orchestra Boosters, is a 501(c)(3) tax exempt organization.
        </p>
      </div>

      <!-- Membership -->
      <div class="mb-12">
        <h2 class="font-serif text-2xl font-bold mb-4">Membership</h2>
        <p class="text-navy-700 leading-relaxed mb-4">
          If you have a student in orchestra you are a booster member. Donations for membership are
          welcome. We are looking to build our team this year to assist with field trips, fund-raising
          and other committee chair positions. If you are interested, please reach out with the
          <a href="/contact" class="text-gold-600 font-medium hover:underline">contact form</a>.
        </p>
        <p class="text-navy-700 leading-relaxed">
          Boosters provide funds to purchase music, maintain equipment, buy necessary instruments,
          uniforms, awards, etc. to support our excellent orchestra program. Your tax-deductible
          contribution will help pay for the expenses throughout the school year.
        </p>
      </div>

      <!-- Donate -->
      <div class="bg-gold-50 border border-gold-200 rounded-xl p-6 md:p-8 mb-12 text-center">
        <h2 class="font-serif text-2xl font-bold mb-4">Make a Donation</h2>
        <p class="text-navy-700 mb-6">
          You can donate online through PayPal, or by check payable to ORHS Orchestra Boosters.
        </p>
        <a
          href="https://www.paypal.com/donate/?hosted_button_id=T32ANDBDFNPHA"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-block bg-navy-900 text-white px-8 py-3 rounded-md font-medium hover:bg-navy-800 transition-colors"
        >
          Donate via PayPal
        </a>
      </div>

      <!-- Ways to Help -->
      <div class="mb-12">
        <h2 class="font-serif text-2xl font-bold mb-6">Other Ways to Help</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div class="border border-navy-200 rounded-xl p-6">
            <h3 class="font-semibold text-lg mb-2">Kroger Community Rewards</h3>
            <p class="text-navy-600 text-sm mb-3">
              Shop at Kroger and they donate to the ORHS Orchestra every time! Sign up with
              our organization code: <strong>RC298</strong>
            </p>
            <a href="/news/kroger-donates" class="text-gold-600 font-medium hover:underline text-sm">
              View enrollment instructions &rarr;
            </a>
          </div>
          <div class="border border-navy-200 rounded-xl p-6">
            <h3 class="font-semibold text-lg mb-2">Concert Donations</h3>
            <p class="text-navy-600 text-sm mb-3">
              Support the orchestra through our tiered donation program with benefits at every level.
            </p>
            <a href="/news/concert-donation-opportunities" class="text-gold-600 font-medium hover:underline text-sm">
              View donation tiers &rarr;
            </a>
          </div>
        </div>
      </div>

      <!-- Uniforms -->
      <div class="mb-12">
        <h2 class="font-serif text-2xl font-bold mb-6">Uniforms</h2>
        <p class="text-navy-700 mb-6">Online ordering for uniforms is available below.</p>
        <div class="flex flex-col sm:flex-row gap-6 items-start mb-6">
          <img
            src="/images/uniform-suit.png"
            alt="Concert suit uniform"
            class="w-32 rounded-lg shadow-md"
          />
          <img
            src="/images/uniform-ladies-options.png"
            alt="Ladies uniform options"
            class="w-48 rounded-lg shadow-md"
          />
        </div>
        <a
          href="https://www.paypal.com/ncp/payment/J96TAPVMQT3ES"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-block bg-navy-900 text-white px-8 py-3 rounded-md font-medium hover:bg-navy-800 transition-colors"
        >
          Purchase Your Uniform
        </a>
      </div>

      <!-- Luthiers -->
      <div>
        <h2 class="font-serif text-2xl font-bold mb-4">Instrument Care</h2>
        <p class="text-navy-700 mb-6">
          Need help with your instrument? Reach out to one of our recommended luthiers for the
          care of your stringed instrument.
        </p>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
          <div class="border border-navy-200 rounded-xl p-6">
            <h3 class="font-semibold text-lg">The Strings Workshop</h3>
            <p class="text-navy-600 mt-1">(865) 483-8075</p>
            <a
              href="https://www.facebook.com/profile.php?id=100057195590775"
              target="_blank"
              rel="noopener noreferrer"
              class="text-gold-600 text-sm hover:underline mt-2 inline-block"
            >
              Visit on Facebook &rarr;
            </a>
          </div>
          <div class="border border-navy-200 rounded-xl p-6">
            <h3 class="font-semibold text-lg">Wilhite Strings</h3>
            <p class="text-navy-600 mt-1">(865) 670-1888</p>
            <a
              href="https://wilhitestrings.com/"
              target="_blank"
              rel="noopener noreferrer"
              class="text-gold-600 text-sm hover:underline mt-2 inline-block"
            >
              Visit website &rarr;
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
